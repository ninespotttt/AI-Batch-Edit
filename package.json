{
  "name": "zdyr-universal-ai-batch-editor",
  "version": "1.0.0",
  "description": "万能AI批量编辑器",
  "main": "src/main/main.cjs",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron:dev": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "start": "concurrently -k \"npm:dev\" \"wait-on http://127.0.0.1:5173 && npm:electron:dev\"",
    "build": "vite build",
    "dist:win": "npm run build && electron-builder --win zip",
    "check": "node --check src/main/main.cjs && node --check src/main/preload.cjs && vite build"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "form-data": "^4.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.2.0",
    "electron-builder": "^26.0.12",
    "lucide-vue-next": "^0.468.0",
    "vite": "^6.3.5",
    "vue": "^3.5.16",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.zdyr.universalbatch",
    "productName": "万能AI批量编辑器",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "zip"
      ],
      "signAndEditExecutable": false,
      "artifactName": "万能AI批量编辑器-win.${ext}"
    }
  }
}
