{
  "appId": "com.zdyr.universalbatch",
  "productName": "万能AI批量编辑器",
  "directories": {
    "app": "protected-main",
    "output": "release-obfuscated"
  },
  "files": [
    "dist/**/*",
    "src/main/**/*",
    "build/icon.ico",
    "notice.json",
    "密钥注册教程.pdf",
    "微信.png",
    "公众号logo.jpg",
    "logo.jpg",
    "package.json"
  ],
  "extraFiles": [
    {
      "from": "密钥注册教程.pdf",
      "to": "密钥注册教程.pdf"
    },
    {
      "from": "微信.png",
      "to": "微信.png"
    },
    {
      "from": "公众号logo.jpg",
      "to": "公众号logo.jpg"
    },
    {
      "from": "logo.jpg",
      "to": "logo.jpg"
    }
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      "zip"
    ],
    "signAndEditExecutable": false,
    "artifactName": "universal-ai-batch-editor-protected-win.${ext}"
  }
}
