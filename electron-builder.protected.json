{
  "appId": "com.zdyr.universalbatch",
  "productName": "万能AI批量编辑器",
  "directories": {
    "app": "protected-main",
    "output": "release-obfuscated"
  },
  "files": [
    "dist/**/*",
    "src/main/**/*",
    "build/icon.ico",
    "notice.json",
    "package.json"
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      "zip"
    ],
    "signAndEditExecutable": false,
    "artifactName": "universal-ai-batch-editor-protected-win.${ext}"
  }
}